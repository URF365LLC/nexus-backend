# ── PostgreSQL / Supabase ─────────────────────────────────────────────────────
PG_HOST=
PG_PORT=5432
PG_DATABASE=postgres
PG_USER=
PG_PASSWORD=

# ── MaxBounty ─────────────────────────────────────────────────────────────────
MAXBOUNTY_USERNAME=
MAXBOUNTY_PASSWORD=
MB_BASE_URL=https://api.maxbounty.com/affiliates/api

# ── Microsoft Advertising / Bing Ad Insight API ───────────────────────────────
BING_DEVELOPER_TOKEN=           # Microsoft Advertising developer token
BING_CLIENT_ID=                 # Azure AD app client ID
BING_CUSTOMER_ID=               # Bing Ads customer ID
BING_ACCOUNT_ID=                # Bing Ads account ID
BING_REFRESH_TOKEN=             # run: npm run bing-auth to generate this
BING_TENANT_ID=                 # Azure AD tenant ID

# ── AI ────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── App ───────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
